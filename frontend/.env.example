# Frontend environment variables (OPTIONAL — only needed for local dev)
#
# In most cases you DON'T need this file. The defaults below work out of the
# box when the backend runs on http://localhost:8000.
#
# Only create frontend/.env.local if:
#   - Your backend runs on a different URL, OR
#   - Your backend has API key auth enabled, OR
#   - You deploy to a public URL and want correct SEO/OG metadata
#
# All real configuration (Gemini key, Voyage key, Tavily key, Qdrant, etc.)
# lives in the BACKEND .env file at the project root. The frontend reads
# settings from the backend via the /api/v1/settings endpoints.

# Backend URL (default: http://localhost:8000)
# VITE_API_BASE=http://localhost:8000

# API Key for auth (only if backend has ENABLE_INSECURE_TOKEN_ENDPOINT=false)
# VITE_API_KEY=your-api-key-here

# API request timeout in milliseconds (default: 60000)
# VITE_API_TIMEOUT_MS=90000

# Public site URL for SEO canonical/OG/Twitter metadata.
# If unset, the runtime origin is used (correct for self-hosted instances).
# Set this only if you deploy to a public domain and want absolute URLs in
# canonical/OG tags. No trailing slash.
# VITE_PUBLIC_URL=https://your-instance.example.com
