# Environment Configuration
# Copy this file to .env and fill in your keys
#
# You can also configure the LLM provider via the web UI at /setup
# after starting the application. The UI writes to SQLite (app_settings
# table) which takes precedence over these env vars.

APP_ENV=production
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Path to the local SQLite database
DATABASE_URL=sqlite:////app/data/cora.db

# -----------------------------------------------------------------------------
# Vector Store Configuration (Qdrant)
# -----------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=cora

# -----------------------------------------------------------------------------
# LLM Provider (answer generation, routing, query rewriting)
# -----------------------------------------------------------------------------
# Supported: gemini (default), openai_compatible
#
# gemini:        Set GEMINI_API_KEY below. Uses Google's Gemini models.
# openai_compatible: Works with OpenAI, Ollama, OpenRouter, LM Studio, etc.
#                   Set LLM_BASE_URL, LLM_API_KEY (if needed), LLM_MODEL_MAIN.
#
# Recommended: Gemini (free tier, strong multilingual support)
# Fully offline: Ollama (no API key, no data leaves your machine)

LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenAI-compatible provider config (uncomment if LLM_PROVIDER=openai_compatible) ---
# LLM_BASE_URL=https://api.openai.com/v1          # OpenAI (recommended model: gpt-4.1-mini)
# LLM_BASE_URL=https://openrouter.ai/api/v1       # OpenRouter (multi-provider)
# LLM_BASE_URL=http://host.docker.internal:11434/v1  # Ollama (from inside Docker)
# LLM_API_KEY=your_openai_compatible_api_key      # Not needed for Ollama
# LLM_MODEL_MAIN=<model-name>                     # See your provider's model list

# -----------------------------------------------------------------------------
# Search Provider (supplementary web search)
# -----------------------------------------------------------------------------
# Supported: tavily (default), none
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=your_tavily_api_key_here
# SEARCH_PROVIDER=none  # Disable web search — answer only from local documents

# -----------------------------------------------------------------------------
# Embedding Provider (document vectorization)
# -----------------------------------------------------------------------------
# Supported: voyage (default), cohere, ollama (local), openai
# Dimension must match the Qdrant collection vector size.
# If you change provider or dimension, re-ingest all documents.
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-4-lite
EMBEDDING_DIM=1024
VOYAGE_API_KEY=your_voyage_api_key_here
# COHERE_API_KEY=your_cohere_api_key_here    # Required when EMBEDDING_PROVIDER=cohere
# OLLAMA_BASE_URL=http://localhost:11434     # For EMBEDDING_PROVIDER=ollama (local)
# OPENAI_API_KEY=your_openai_api_key_here    # Required when EMBEDDING_PROVIDER=openai

# -----------------------------------------------------------------------------
# Reranker Provider (retrieval quality improvement)
# -----------------------------------------------------------------------------
# Supported: voyage (default), cohere, none (skip — fully offline)
RERANK_PROVIDER=voyage
RERANK_MODEL=rerank-2.5
# RERANK_PROVIDER=none  # Disable reranking

# -----------------------------------------------------------------------------
# KB Relevance Filtering (four-layer defense chain — see CLAUDE.md)
# -----------------------------------------------------------------------------
# Layer 1: hard rerank floor (docs below this are dropped post-rerank)
RERANK_SCORE_THRESHOLD=0.2
# Layer 1: zero-cost lexical overlap guard (opt-in — computes MAX overlap
# across both the original and rewritten query forms so acronym expansion
# doesn't unfairly lower overlap). 0.0 = disabled.
QUERY_DOC_OVERLAP_THRESHOLD=0.0
# Layer 2: pre-generation gate — if best doc's rerank score < this, skip KB → web
KB_MIN_TOP_RELEVANCE_SCORE=0.4
# Per-collection JSON overrides for any of the above thresholds.
# Example: {"my_collection": {"KB_MIN_TOP_RELEVANCE_SCORE": 0.5}}
# COLLECTION_RELEVANCE_OVERRIDES=

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# SQLite persistent cache (survives application restarts)
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400

# PII redaction before storing conversation memory
# Set to false to disable (e.g. for local-only deployments where you own the data)
PII_REDACTION_ENABLED=true

# Secret key for signing conversation history and anonymizing memory user IDs.
# AUTO-GENERATED on first run and persisted to SQLite — no setup needed.
# Set it here only if you want to use your own key (e.g. for multi-instance deployments
# that need to share signed history). Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=

# -----------------------------------------------------------------------------
# Document Ingestion — PDF Conversion Modes
# -----------------------------------------------------------------------------
# standard: Docling classical pipeline (layout model + RapidOCR + TableFormer).
#           Free, runs on CPU, local (no data leaves the machine). Preserves
#           headings, tables, and reading order; OCRs scanned pages.
#           ~1-2s/page on properly provisioned hardware. No VLM is loaded.
# llm_api:  AI service (Gemini/OpenAI), high accuracy on complex layouts, images,
#           and formulas. Requires a paid API key. ~$0.002/page.
#           Power users: point llm_api at a local vLLM server (e.g. PaddleOCR-VL-1.6)
#           by setting OPENAI_BASE_URL=http://localhost:8001/v1 — a config change.
# DOCUMENT_PDF_RENDER_DPI=200

# For local development without docker you can specify:
# CORS_ORIGINS=http://localhost:8080,http://localhost:8000
