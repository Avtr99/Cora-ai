# =============================================================================
# Cora AI — Root .gitignore
# =============================================================================
# Backend (Python/FastAPI), Frontend (Vite/React/TypeScript), Docker.
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & credentials — NEVER commit
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets.json
credentials.json
app_settings.json
service-account*.json

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.eggs/
build/
dist/
wheels/
sdist/
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / lint / type caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
coverage.json

# -----------------------------------------------------------------------------
# Node.js / Frontend
# -----------------------------------------------------------------------------
node_modules/
dist-ssr/
*.tsbuildinfo

# Frontend test & coverage
coverage/
.nyc_output/
test-results/
playwright-report/
blob-report/
storybook-static/

# Frontend caches
.cache/
.turbo/
.tmp/

# Frontend build output (generated by Dockerfile / npm run build)
frontend/dist/

# Frontend local env (keep .env.example)
frontend/.env
frontend/.env.*
!frontend/.env.example

# Frontend debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Databases & local runtime data (may contain user data / API keys)
# -----------------------------------------------------------------------------
*.sqlite3
*.sqlite
*.db
*.db-journal
*.db-wal
*.db-shm
/data/
!data/.gitkeep

# Ingestion checkpoints
.ingestion_checkpoints/

# -----------------------------------------------------------------------------
# Evaluation & test artifacts
# -----------------------------------------------------------------------------
results/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# IDE & editor
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# AI agent / pair-programmer tool directories (local only, never committed)
# -----------------------------------------------------------------------------
.claude/
.devin/
.fallow/
.windsurf/
.windsurfrules

# AI agent guidance files (kept locally, not committed)
CLAUDE.md
AGENTS.md

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Temporary & backup files
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.orig

# -----------------------------------------------------------------------------
# Frontend data artifacts (app uses generated JSON, not raw CSVs)
# -----------------------------------------------------------------------------
frontend/data/Voluntary-Registry-Offsets-Database--*.csv
frontend/data/Document sources.csv
frontend/public/data/Document sources.csv

# -----------------------------------------------------------------------------
# Document update checker & bundle analysis artifacts
# -----------------------------------------------------------------------------
document-update-baseline.json
document-update-report.json
bundle-report.json
tests/test_secret_key_auto.py
